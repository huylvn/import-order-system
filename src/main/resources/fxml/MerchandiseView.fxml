<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.importorder.controller.MerchandiseController"
            styleClass="master-view">
    <top>
        <Label text="Quản lý mặt hàng" styleClass="view-title">
            <padding>
                <Insets top="16" right="16" bottom="8" left="16"/>
            </padding>
        </Label>
    </top>
    <center>
        <TableView fx:id="merchandiseTable" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="codeColumn" text="Mã" prefWidth="100"/>
                <TableColumn fx:id="nameColumn" text="Tên" prefWidth="180"/>
                <TableColumn fx:id="unitColumn" text="Đơn vị" prefWidth="80"/>
                <TableColumn fx:id="descriptionColumn" text="Mô tả" prefWidth="240"/>
            </columns>
            <padding>
                <Insets left="16" right="16"/>
            </padding>
        </TableView>
    </center>
    <bottom>
        <VBox spacing="12" styleClass="form-panel">
            <padding>
                <Insets top="12" right="16" bottom="16" left="16"/>
            </padding>
            <GridPane hgap="10" vgap="10">
                <Label text="Mã:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="codeField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200"/>
                <Label text="Tên:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="280"/>
                <Label text="Đơn vị:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="unitField" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="120"/>
                <Label text="Mô tả:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="descriptionField" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="320"/>
            </GridPane>
            <HBox spacing="8">
                <Button text="Thêm" onAction="#onAdd"/>
                <Button text="Cập nhật" onAction="#onUpdate"/>
                <Button text="Xóa" onAction="#onDelete"/>
                <Button text="Làm sạch" onAction="#onClear"/>
                <Button text="Làm mới" onAction="#onRefresh"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
