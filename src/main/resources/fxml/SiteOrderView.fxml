<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.importorder.controller.SiteOrderController"
            styleClass="master-view">
    <top>
        <VBox spacing="8">
            <padding>
                <Insets top="16" right="16" bottom="8" left="16"/>
            </padding>
            <Label text="Đơn đặt site" styleClass="view-title"/>
            <HBox spacing="8">
                <Button text="Làm mới" onAction="#onRefresh"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="12">
            <padding>
                <Insets left="16" right="16" bottom="16"/>
            </padding>
            <TableView fx:id="siteOrderTable" prefHeight="280">
                <columns>
                    <TableColumn fx:id="orderIdColumn" text="Mã đơn" prefWidth="90"/>
                    <TableColumn fx:id="importRequestCodeColumn" text="Mã yêu cầu nhập" prefWidth="180"/>
                    <TableColumn fx:id="siteCodeColumn" text="Mã site" prefWidth="110"/>
                    <TableColumn fx:id="siteNameColumn" text="Tên site" prefWidth="180"/>
                    <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="110"/>
                    <TableColumn fx:id="createdAtColumn" text="Tạo lúc" prefWidth="210"/>
                    <TableColumn fx:id="sentAtColumn" text="Gửi lúc" prefWidth="210"/>
                </columns>
            </TableView>
            <Label text="Chi tiết đơn đặt" styleClass="section-title"/>
            <TableView fx:id="orderItemTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="merchandiseCodeColumn" text="Mã mặt hàng" prefWidth="160"/>
                    <TableColumn fx:id="merchandiseNameColumn" text="Tên mặt hàng" prefWidth="220"/>
                    <TableColumn fx:id="quantityOrderedColumn" text="Số lượng đặt" prefWidth="150"/>
                    <TableColumn fx:id="unitColumn" text="Đơn vị" prefWidth="90"/>
                    <TableColumn fx:id="deliveryMeansColumn" text="Phương thức giao" prefWidth="160"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
