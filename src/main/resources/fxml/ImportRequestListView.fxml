<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:id="importRequestRoot"
           fx:controller="com.importorder.controller.ImportRequestController"
           styleClass="master-view">
    <BorderPane fx:id="listContent">
        <top>
            <VBox spacing="8">
                <padding>
                    <Insets top="16" right="16" bottom="8" left="16"/>
                </padding>
                <Label text="Yêu cầu nhập hàng" styleClass="view-title"/>
                <HBox spacing="8">
                    <Button text="Tạo yêu cầu mới" onAction="#onCreateNewRequest"/>
                    <Button fx:id="viewDetailButton" text="Xem chi tiết" onAction="#onViewDetail" disable="true"/>
                    <Button fx:id="submitRequestButton" text="Gửi yêu cầu" onAction="#onSubmitSelectedRequest" disable="true"/>
                    <Button text="Chạy phân bổ" onAction="#onRunAllocation"/>
                </HBox>
            </VBox>
        </top>
        <center>
            <TableView fx:id="requestTable" BorderPane.alignment="CENTER">
                <columns>
                    <TableColumn fx:id="requestCodeColumn" text="Mã yêu cầu" prefWidth="180"/>
                    <TableColumn fx:id="requestDateColumn" text="Ngày yêu cầu" prefWidth="140"/>
                    <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="170"/>
                    <TableColumn fx:id="createdAtColumn" text="Tạo lúc" prefWidth="220"/>
                </columns>
                <padding>
                    <Insets left="16" right="16" bottom="16"/>
                </padding>
            </TableView>
        </center>
    </BorderPane>
</StackPane>
