<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.importorder.controller.MainController"
            styleClass="root-pane">

    <left>
        <VBox styleClass="sidebar" spacing="4" prefWidth="240">
            <padding>
                <Insets top="20" right="16" bottom="20" left="16"/>
            </padding>

            <Label text="Hệ thống đặt hàng nhập khẩu" styleClass="sidebar-title"/>
            <Label text="Phân bổ đơn hàng" styleClass="sidebar-subtitle"/>
            <Separator styleClass="sidebar-separator"/>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="sidebar-scroll">
                <VBox spacing="4">
                    <Button text="Tổng quan" styleClass="nav-button,nav-button-active"
                            fx:id="dashboardButton" onAction="#onDashboard" maxWidth="Infinity"/>
                    <Button text="Mặt hàng" styleClass="nav-button"
                            fx:id="merchandiseButton" onAction="#onMerchandise" maxWidth="Infinity"/>
                    <Button text="Site nhập khẩu" styleClass="nav-button"
                            fx:id="importSiteButton" onAction="#onImportSite" maxWidth="Infinity"/>
                    <Button text="Danh mục site" styleClass="nav-button"
                            fx:id="siteCatalogButton" onAction="#onSiteCatalog" maxWidth="Infinity"/>
                    <Button text="Tồn kho" styleClass="nav-button"
                            fx:id="inventoryButton" onAction="#onInventory" maxWidth="Infinity"/>
                    <Button text="Yêu cầu nhập hàng" styleClass="nav-button"
                            fx:id="importRequestButton" onAction="#onImportRequest" maxWidth="Infinity"/>
                    <Button text="Kết quả phân bổ" styleClass="nav-button"
                            fx:id="allocationResultButton" onAction="#onAllocationResult" maxWidth="Infinity"/>
                    <Button text="Đơn đặt site" styleClass="nav-button"
                            fx:id="siteOrderButton" onAction="#onSiteOrder" maxWidth="Infinity"/>
                    <Button text="Nhập kho" styleClass="nav-button"
                            fx:id="warehouseReceivingButton" onAction="#onWarehouseReceiving" maxWidth="Infinity"/>
                </VBox>
            </ScrollPane>
        </VBox>
    </left>

    <center>
        <StackPane styleClass="content-wrapper">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <StackPane fx:id="contentArea" styleClass="content-area"/>
        </StackPane>
    </center>

    <bottom>
        <Label fx:id="statusLabel" text="Sẵn sàng" styleClass="status-bar">
            <padding>
                <Insets top="8" right="16" bottom="8" left="16"/>
            </padding>
        </Label>
    </bottom>
</BorderPane>
