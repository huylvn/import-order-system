<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.importorder.controller.InventoryController"
            styleClass="master-view">
    <top>
        <Label text="Quản lý tồn kho" styleClass="view-title">
            <padding>
                <Insets top="16" right="16" bottom="8" left="16"/>
            </padding>
        </Label>
    </top>
    <center>
        <TableView fx:id="inventoryTable">
            <columns>
                <TableColumn fx:id="siteCodeColumn" text="Mã site" prefWidth="100"/>
                <TableColumn fx:id="merchandiseCodeColumn" text="Mã mặt hàng" prefWidth="140"/>
                <TableColumn fx:id="quantityColumn" text="Số lượng tồn" prefWidth="110"/>
                <TableColumn fx:id="unitColumn" text="Đơn vị" prefWidth="80"/>
                <TableColumn fx:id="lastUpdatedColumn" text="Cập nhật lúc" prefWidth="180"/>
            </columns>
            <padding>
                <Insets left="16" right="16"/>
            </padding>
        </TableView>
    </center>
    <bottom>
        <VBox spacing="12" styleClass="form-panel">
            <padding>
                <Insets top="12" right="16" bottom="16" left="16"/>
            </padding>
            <GridPane hgap="10" vgap="10">
                <Label text="Site nhập khẩu:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <ComboBox fx:id="siteComboBox" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="260"/>
                <Label text="Mặt hàng:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <ComboBox fx:id="merchandiseComboBox" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="260"/>
                <Label text="Số lượng tồn:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="quantityField" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="120"/>
                <Label text="Đơn vị:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="unitField" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="120"/>
            </GridPane>
            <HBox spacing="8">
                <Button text="Lưu tồn kho" onAction="#onSave"/>
                <Button text="Làm sạch form" onAction="#onClear"/>
                <Button text="Làm mới" onAction="#onRefresh"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
