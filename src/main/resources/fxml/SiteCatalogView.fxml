<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.importorder.controller.SiteCatalogController"
            styleClass="master-view">
    <top>
        <VBox spacing="12">
            <padding>
                <Insets top="16" right="16" bottom="8" left="16"/>
            </padding>
            <Label text="Danh mục mặt hàng theo site" styleClass="view-title"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Site nhập khẩu:"/>
                <ComboBox fx:id="siteComboBox" prefWidth="260"/>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Gán mặt hàng:"/>
                <ComboBox fx:id="merchandiseComboBox" prefWidth="260"/>
                <Button text="Gán" onAction="#onAssign"/>
                <Button text="Xóa dòng chọn" onAction="#onRemove"/>
                <Button text="Làm mới" onAction="#onRefresh"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="catalogTable">
            <columns>
                <TableColumn fx:id="codeColumn" text="Mã" prefWidth="120"/>
                <TableColumn fx:id="nameColumn" text="Tên" prefWidth="200"/>
                <TableColumn fx:id="unitColumn" text="Đơn vị" prefWidth="80"/>
            </columns>
            <padding>
                <Insets left="16" right="16" bottom="16"/>
            </padding>
        </TableView>
    </center>
</BorderPane>
