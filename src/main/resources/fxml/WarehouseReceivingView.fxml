<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.importorder.controller.WarehouseController"
            styleClass="master-view">
    <top>
        <VBox spacing="12">
            <padding>
                <Insets top="16" right="16" bottom="8" left="16"/>
            </padding>
            <Label text="Nhập kho" styleClass="view-title"/>
            <HBox spacing="8">
                <Label text="Đơn đặt site:"/>
                <ComboBox fx:id="siteOrderComboBox" prefWidth="360"/>
                <Button fx:id="receiveGoodsButton" text="Ghi nhận nhập kho" onAction="#onReceiveGoods" disable="true"/>
                <Button text="Làm mới" onAction="#onRefresh"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="receiveItemTable" editable="true" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="merchandiseCodeColumn" text="Mã mặt hàng" prefWidth="150"/>
                <TableColumn fx:id="merchandiseNameColumn" text="Tên mặt hàng" prefWidth="220"/>
                <TableColumn fx:id="quantityOrderedColumn" text="Số lượng đặt" prefWidth="150"/>
                <TableColumn fx:id="unitColumn" text="Đơn vị" prefWidth="80"/>
                <TableColumn fx:id="deliveryMeansColumn" text="Phương thức giao" prefWidth="150"/>
                <TableColumn fx:id="actualReceivedQuantityColumn" text="Số lượng thực nhận" prefWidth="190"/>
                <TableColumn fx:id="noteColumn" text="Ghi chú" prefWidth="220"/>
                <TableColumn fx:id="receivedStatusColumn" text="Trạng thái" prefWidth="120"/>
            </columns>
            <padding>
                <Insets left="16" right="16" bottom="16"/>
            </padding>
        </TableView>
    </center>
</BorderPane>
