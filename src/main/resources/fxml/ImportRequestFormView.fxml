<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            styleClass="master-view">
    <top>
        <VBox spacing="12">
            <padding>
                <Insets top="16" right="16" bottom="8" left="16"/>
            </padding>
            <HBox spacing="8">
                <Button text="Quay lại" onAction="#onBackToList"/>
                <Label fx:id="formTitleLabel" text="Tạo yêu cầu nhập hàng" styleClass="view-title"/>
            </HBox>
            <GridPane hgap="10" vgap="10">
                <Label text="Mã yêu cầu:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="requestCodeField" prefWidth="260" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label text="Ngày yêu cầu:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <DatePicker fx:id="requestDatePicker" prefWidth="180" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
            </GridPane>
        </VBox>
    </top>
    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="8" right="16" bottom="8" left="16"/>
            </padding>
            <Label text="Danh sách mặt hàng yêu cầu" styleClass="section-title"/>
            <GridPane hgap="10" vgap="10">
                <Label text="Mặt hàng:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <ComboBox fx:id="merchandiseComboBox" prefWidth="260" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label text="Số lượng đặt:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <TextField fx:id="quantityField" prefWidth="120" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                <Label text="Đơn vị:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="unitField" prefWidth="120" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label text="Ngày giao mong muốn:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <DatePicker fx:id="desiredDeliveryDatePicker" prefWidth="180" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
            </GridPane>
            <HBox spacing="8">
                <Button fx:id="addItemButton" text="Thêm mặt hàng" onAction="#onAddItem"/>
                <Button fx:id="removeItemButton" text="Xóa mặt hàng" onAction="#onRemoveItem"/>
            </HBox>
            <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="merchandiseColumn" text="Mặt hàng" prefWidth="260"/>
                    <TableColumn fx:id="quantityColumn" text="Số lượng đặt" prefWidth="150"/>
                    <TableColumn fx:id="unitColumn" text="Đơn vị" prefWidth="100"/>
                    <TableColumn fx:id="desiredDeliveryDateColumn" text="Ngày giao mong muốn" prefWidth="180"/>
                </columns>
            </TableView>
        </VBox>
    </center>
    <bottom>
        <HBox spacing="8" styleClass="form-panel">
            <padding>
                <Insets top="12" right="16" bottom="16" left="16"/>
            </padding>
            <Button fx:id="saveDraftButton" text="Lưu nháp" onAction="#onSaveDraft"/>
            <Button fx:id="submitFormButton" text="Gửi yêu cầu" onAction="#onSubmitForm"/>
        </HBox>
    </bottom>
</BorderPane>
